     <property name="styleSheet">
      <string notr="true">
QPushButton {
	font: 7pt ;
    background-color: #e0e0e0; /* Couleur de fond par défaut */
    color: #808080; /* Couleur du texte par défaut (gris clair) */
    border: 1px solid #808080; /* Bordure grise par défaut */
    border-radius: 7px; /* Arrondir les coins par défaut */
}

/* Style lorsque la souris survole le bouton */
QPushButton:hover {
    background-color: #fafad2; /* Nouvelle couleur de fond lorsque le lineEdit est en focus */
    color: #000000; /* Nouvelle couleur du texte lorsque le lineEdit est en focus (noir) */
    border-color: #D3D3D3; /* Nouvelle couleur de la bordure lorsque le lineEdit est en focus */
}

/* Style lorsque le bouton est enfoncé */
QPushButton:pressed {
    background-color: #b8860b; /* Couleur de fond en cas d'appui */
    border: 1px solid #446cff; /* Bordure en cas d'appui */
}

/* Style lorsque le bouton est enfoncé et coché (utilisé pour les boutons à bascule) */
QPushButton:checked {
    background-color: #3761ff; /* Couleur de fond en cas de bouton coché */
    border: 1px solid #3761ff; /* Bordure en cas de bouton coché */
}




</string>
