     <property name="styleSheet">
      <string notr="true">QPushButton {
	image: url(:/images/img/envoyer.png);
	
	font: 12pt &quot;Century Gothic&quot;;
    background-color: #191970; /* Couleur de fond */
    color: #fff; /* Couleur du texte */
    border: none; /* Pas de bordure */
    border-radius: 10px; /* Arrondir les coins */
}

/* Style lorsque la souris survole le bouton */
QPushButton:hover {
	color: rgb(255, 255, 255);

background:#DAA520;
border: none;
}

/* Style lorsque le bouton est enfoncé */
QPushButton:pressed {
    background-color: #b8860b; /* Couleur de fond en cas d'appui */
    border: 1px solid #446cff; /* Bordure en cas d'appui */
}

/* Style lorsque le bouton est enfoncé et coché (utilisé pour les boutons à bascule) */
QPushButton:checked {
    background-color: #3761ff; /* Couleur de fond en cas de bouton coché */
    border: 1px solid #3761ff; /* Bordure en cas de bouton coché */
}




</string>
     </property>
     <property name="text">
      <string/>
     </property>
    </widget>
