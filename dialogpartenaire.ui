     <property name="styleSheet">
      <string notr="true">/* Style for QComboBox */
QComboBox {
    background-color: #1a1a49;
    border: 2px solid rgb(255, 170, 255);
    color: rgb(255, 255,255);
    padding: 6px; /* Adjust padding as needed */
    border-radius: 4px;
}

/* Dropdown arrow color */
QComboBox::down-arrow {
    color: white;
}

/* Placeholder text color */
QComboBox::placeholderText {
    color: rgba(255, 255, 255, 0.7);
}

/* Border and background color on focus */
QComboBox:focus {
    border: 2px solid #abdbe3; /* Change color on focus */
    background-color: #2a2a69; /* Change background color on focus */
}
